# JWT
JWT_ACCESS_SECRET=replace-with-a-random-64-character-access-secret
JWT_REFRESH_SECRET=replace-with-a-random-64-character-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Cookies / proxy
COOKIE_NAME_REFRESH=refreshToken
COOKIE_SECURE=false
TRUST_PROXY=true

# Security / CORS
CORS_ORIGIN_WHITELIST=http://localhost:3000,http://localhost:3001
BCRYPT_COST=12
LOG_LEVEL=info

